-- NO TEXTURE (GIU NGUYEN) + DELETED HAND (VISUAL ONLY)
-- 1 script duy nhat | Server-side

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

--------------------------------------------------
-- NO TEXTURE (GIU NGUYEN)
--------------------------------------------------
local function applyNoTexture(root)
	for _,v in ipairs(root:GetDescendants()) do
		if v:IsA("BasePart") then
			v.Material = Enum.Material.Plastic
			v.Reflectance = 0
			v.CastShadow = false
			if v:IsA("MeshPart") then
				v.TextureID = ""
			end
		elseif v:IsA("Decal") or v:IsA("Texture") then
			v.Transparency = 1
		elseif v:IsA("SurfaceAppearance") then
			v.ColorMap = ""
			v.NormalMap = ""
			v.RoughnessMap = ""
			v.MetalnessMap = ""
		elseif v:IsA("SpecialMesh") then
			v.TextureId = ""
		elseif v:IsA("ParticleEmitter")
			or v:IsA("Trail")
			or v:IsA("Beam")
			or v:IsA("Smoke")
			or v:IsA("Fire") then
			v.Enabled = false
		end
	end
end

-- áp dụng toàn map
applyNoTexture(Workspace)

Workspace.DescendantAdded:Connect(function(obj)
	task.wait()
	applyNoTexture(obj)
end)

--------------------------------------------------
-- DELETED HAND (VISUAL)
--------------------------------------------------
local HAND_NAMES = {
	"LeftHand","RightHand",
	"Left Arm","Right Arm" -- fallback R6
}

local function addDeletedVisual(part)
	-- làm tay trong suốt (visual)
	part.Transparency = 1
	part.CanCollide = false

	-- outline để còn thấy vị trí
	local hl = Instance.new("Highlight")
	hl.FillTransparency = 1
	hl.OutlineTransparency = 0
	hl.OutlineColor = Color3.fromRGB(255, 80, 80)
	hl.Parent = part

	-- chữ DELETED nổi trên tay
	local gui = Instance.new("BillboardGui")
	gui.Size = UDim2.fromScale(2, 1)
	gui.StudsOffset = Vector3.new(0, 0.5, 0)
	gui.AlwaysOnTop = true
	gui.Parent = part

	local txt = Instance.new("TextLabel")
	txt.Size = UDim2.fromScale(1, 1)
	txt.BackgroundTransparency = 1
	txt.Text = "DELETED"
	txt.TextColor3 = Color3.fromRGB(255, 60, 60)
	txt.TextStrokeTransparency = 0
	txt.Font = Enum.Font.Arcade
	txt.TextScaled = true
	txt.Parent = gui
end

local function onCharacter(char)
	for _,name in ipairs(HAND_NAMES) do
		local p = char:FindFirstChild(name, true)
		if p and p:IsA("BasePart") then
			addDeletedVisual(p)
		end
	end
end

Players.PlayerAdded:Connect(function(plr)
	plr.CharacterAdded:Connect(onCharacter)
end)

-- áp cho player đang có sẵn
for _,plr in ipairs(Players:GetPlayers()) do
	if plr.Character then
		onCharacter(plr.Character)
	end
	plr.CharacterAdded:Connect(onCharacter)
end
